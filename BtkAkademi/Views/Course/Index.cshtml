@model IEnumerable<Candidate>

@if (Model.Count() > 0)
{
    <h6 class="display-6"> Applications(@Model.Count()) </h6>

    //hover table stripped
    <table class="table table-hover table-striped">
        <thead>
            <tr>
                <th> Email </th>
                <th> FullName </th>
                <th> ApplyAt </th>
                <th> Course </th>
            </tr>
        </thead>
        <tbody>
            @foreach (Candidate candidate in Model)
            {
                <tr>
                    <td> @candidate.Email </td>
                    <td> @candidate.FullName </td>
                    <td> @candidate.ApplyAt </td>
                    <td> @candidate.SelectedCourse </td>
                </tr>
            }
        </table>
    }
else
    {
        <div class="alert alert-info">
            There is no application. Please click here to
            <a class="alert-link" asp-action="Apply"> Apply </a>
        </div>
    }